<UserControl x:Class="WindowsDev.Controls.Users.HeaderTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Margin="{Binding FieldMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"
          HorizontalAlignment="Stretch">

        <mah:MetroHeader Header="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         FontSize="{Binding HeaderFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Foreground="{Binding HeaderForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         HorizontalAlignment="Stretch"
                         HorizontalContentAlignment="Stretch">

            <TextBox Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="{Binding TextWrapping, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     VerticalScrollBarVisibility="{Binding ScrollBarVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}"

                     Height="{Binding FieldHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     HorizontalAlignment="Stretch"
                     AcceptsReturn="True"

                     mah:TextBoxHelper.Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     mah:ControlsHelper.CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        </mah:MetroHeader>

    </Grid>

</UserControl>