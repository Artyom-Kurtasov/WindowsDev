<UserControl x:Class="WindowsDev.Controls.Users.HeaderPasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:WindowsDev.Business.Services.Registration.Validation.Converters;assembly=WindowsDev.Business"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    

    <UserControl.Resources>
        <!-- Error Template -->
        <ControlTemplate x:Key="RoundedErrorTemplate">
            <Border BorderBrush="Red"
                    BorderThickness="2"
                    CornerRadius="8">
                <AdornedElementPlaceholder />
            </Border>
        </ControlTemplate>

        <!-- Converters -->
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </UserControl.Resources>

    <!-- Main Grid -->
    <Grid HorizontalAlignment="Stretch">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Row with Optional Link -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="{Binding HeaderFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{Binding HeaderForeground, RelativeSource={RelativeSource AncestorType=UserControl}}" />

            <!-- Optional Link (e.g., Forgot Password) -->
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="{Binding HorizontalAlignmentHyperlink, RelativeSource={RelativeSource AncestorType=UserControl}}">

                <Hyperlink Command="{Binding LinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Run Text="{Binding LinkText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </Hyperlink>

            </TextBlock>

        </Grid>

        <!-- Password Input -->
        <PasswordBox Grid.Row="1"
                     x:Name="PART_PasswordBox"

                     mah:PasswordBoxBindingBehavior.Password="{Binding Password, RelativeSource={RelativeSource AncestorType=UserControl}}"

                     mah:TextBoxHelper.Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                     mah:ControlsHelper.CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"

                     Validation.ErrorTemplate="{StaticResource RoundedErrorTemplate}" />

        <!-- Password Requirements (Conditional Display) -->
        <TextBlock Grid.Row="2"
           FontSize="10"
           Margin="0,5,0,0">

            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding ShowRequirements, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                    </Style.Triggers>
                </Style>
            </TextBlock.Style>

            <!-- Minimum Length Requirement -->
            <Run Text="{DynamicResource Registration_Requirement_MinLength}"
                Foreground="{Binding HasMinimumLength, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToBrushConverter}}"/>

            <LineBreak/>

            <!-- Number Requirement -->
            <Run Text="{DynamicResource Registration_Requirement_Number}"
                Foreground="{Binding HasNumber, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToBrushConverter}}"/>

            <LineBreak/>

            <!-- Uppercase Requirement -->
            <Run Text="{DynamicResource Registration_Requirement_Uppercase}"
                Foreground="{Binding HasUppercase, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToBrushConverter}}"/>

            <LineBreak/>

            <!-- Symbol Requirement -->
            <Run Text="{DynamicResource Registration_Requirement_SpecialSymbol}"
                Foreground="{Binding HasSymbol, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToBrushConverter}}"/>

        </TextBlock>

    </Grid>

</UserControl>
