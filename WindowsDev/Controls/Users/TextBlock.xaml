<UserControl x:Class="WindowsDev.Controls.Users.TextBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.Controls.Users"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="{Binding FieldMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"
      HorizontalAlignment="Stretch" >

        <mah:MetroHeader Header="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Top">

            <Border BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    HorizontalAlignment="Stretch" MinHeight="20" MaxHeight="200">
                <TextBlock
                    x:Name="PART_TextBlock"
                    MinHeight="20" MaxHeight="200"
                    HorizontalAlignment="Stretch"
                    Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    TextWrapping="{Binding Wrapping, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Border>
        </mah:MetroHeader>
    </Grid>
</UserControl>
