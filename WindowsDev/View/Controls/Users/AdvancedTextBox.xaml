<UserControl x:Class="WindowsDev.View.Controls.AdvancedTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="control">

    <Grid HorizontalAlignment="Stretch"
          Margin="{Binding FieldMargin, RelativeSource={RelativeSource AncestorType=UserControl}}">

        <mah:MetroHeader
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Header="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}">

            <TextBox x:Name="PART_TextBox"
                     AcceptsReturn="True"
                     HorizontalAlignment="Stretch"
                     TextWrapping="{Binding TextWrapping, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     VerticalScrollBarVisibility="{Binding ScrollBarVisibility, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Height="{Binding FieldHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     mah:TextBoxHelper.UseFloatingWatermark="{Binding UseWatermark, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     mah:TextBoxHelper.Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     mah:ControlsHelper.CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        </mah:MetroHeader>

    </Grid>

</UserControl>
