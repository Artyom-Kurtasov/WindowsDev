<UserControl x:Class="WindowsDev.View.Controls.WindowsContent.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:UserCtrl="clr-namespace:WindowsDev.View.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.View.Controls.WindowsContent"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                   Orientation="Horizontal" 
                   Margin="0,0,0,20">

            <Button Content="Update task" 
                   mah:ControlsHelper.CornerRadius="6"
                   Padding="16,8" 
                   Margin="0,0,8,0"
                   FontWeight="SemiBold"
                   ToolTip="Update task details"
                    Command="{Binding EditTaskCommand}"/>

            <Button Content="Delete task" 
                   mah:ControlsHelper.CornerRadius="6"
                   Padding="16,8"
                   FontWeight="SemiBold"
                   ToolTip="Delete current task"/>

            <Button Content="Back"
                    mah:ControlsHelper.CornerRadius="8"
                    Padding="16, 8"
                    Command="{Binding SwitchToProjectCommand}"/>
        </StackPanel>

        <Border Grid.Row="1" 
                Padding="16" 
                Margin="0,0,0,20">
            <TextBlock Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="2" 
              mah:ControlsHelper.CornerRadius="8"
              Margin="0,0,0,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <UserCtrl:TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,16"
                                   Header="Status"
                                   Text="{Binding Status, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"/>

            <UserCtrl:TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                Header="Priority"   
                                Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                FontSize="16" 
                                FontWeight="SemiBold"/>

            <UserCtrl:TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0,0,16"
                                Header="Progress"
                                Text="{Binding Progress, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                FontSize="16" 
                                FontWeight="SemiBold"/>

            <UserCtrl:TextBlock Grid.Row="1" Grid.Column="1" Margin="8,0,0,0"
                                Header="Created"
                                Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" 
                                FontSize="16" 
                                FontWeight="SemiBold"/>
        </Grid>

        <UserCtrl:TextBlock 
            Header="Description"
            Grid.Row="3" 
            mah:ControlsHelper.CornerRadius="8"
            Margin="0,0,0,20" 
            CornerRadius="8" 
            Wrapping="Wrap"
            Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <StackPanel Grid.Row="4" 
                   mah:ControlsHelper.CornerRadius="8"
                   Margin="0,0,0,20">

            <TextBlock Text="Attachments" 
                      FontSize="16" 
                      FontWeight="SemiBold" 
                      Foreground="#2196F3" 
                      Margin="0,0,0,12"/>

            <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="6"
                               Padding="8"
                               Margin="0,0,0,4"
                               BorderBrush="#E0E0E0"
                               BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                          Text="📎" 
                                          Margin="0,0,8,0"
                                          FontSize="16"/>

                                <StackPanel Grid.Column="1" 
                                          Orientation="Horizontal"
                                          Margin="0,0,8,0">
                                    <TextBlock Text="{Binding FileName}" 
                                              FontWeight="Medium"
                                              Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding FileSize}" 
                                              FontSize="11"
                                              Foreground="#757575"/>
                                </StackPanel>

                                <Button Grid.Column="2" 
                                       Content="📥"
                                       mah:ControlsHelper.CornerRadius="4"
                                       Padding="8,4"
                                       FontSize="14"
                                       ToolTip="Download"
                                       Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add attachment"
                   mah:ControlsHelper.CornerRadius="6"
                   Padding="16,8"
                   HorizontalAlignment="Left"
                   Command="{Binding AddAttachmentCommand}"/>
        </StackPanel>

        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                      Text="Comments" 
                      FontSize="16" 
                      FontWeight="SemiBold" 
                      Foreground="#2196F3" 
                      Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding Comments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6"
                                   Padding="12"
                                   Margin="0,0,0,8"
                                   BorderBrush="#E0E0E0"
                                   BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                              Text="{Binding Author}" 
                                              FontWeight="SemiBold"
                                              Margin="0,0,8,4"/>

                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                              Text="{Binding CreatedAt}" 
                                              FontSize="11"
                                              Foreground="#757575"
                                              HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                              Grid.ColumnSpan="2"
                                              Text="{Binding Text}" 
                                              TextWrapping="Wrap"
                                              FontSize="13"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                        mah:TextBoxHelper.Watermark="Add a comment..."
                        Margin="0,0,8,0"
                        Padding="8"
                        Text="{Binding NewComment, Mode=TwoWay}"/>

                <Button Grid.Column="1" 
                       Content="Post"
                       mah:ControlsHelper.CornerRadius="6"
                       Padding="16,8"
                       Command="{Binding AddCommentCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>