<UserControl x:Class="WindowsDev.View.Controls.WindowsContent.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.View.Controls.WindowsContent"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel>
            <TabControl Style="{DynamicResource MahApps.Styles.TabControl.AnimatedSingleRow}">
                <TabItem Header="{DynamicResource ProjectsLabel}">
                    <Grid>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource AddButton}" Background="Transparent" BorderBrush="Transparent"
                                        Command="{Binding OpenDialogCommand}"/>
                                <Button Content="{DynamicResource DeleteButton}" Background="Transparent" BorderBrush="Transparent"
                                        Command="{Binding DeleteSelectedProjectsCommand}"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding ProjectList}"
                                      AutoGenerateColumns="false"
                                      SelectionMode="Extended"
                                      SelectionUnit="Cell"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                      Style="{DynamicResource MetroDataGridCheckBox}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Binding="{Binding Id}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource IdLabel}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Width="1*">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource NameLabel}"/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Hyperlink Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               CommandParameter="{Binding}">
                                                        <Run Text="{Binding Name}" Foreground="White"/>
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Width="3*">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource DescriptionLabel}"/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy}}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource CreatedAtLabel}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource SettingsLabel}">
                    <Grid>
                        <StackPanel>
                            <ComboBox SelectedValuePath="Tag"
                              SelectedValue="{Binding SelectedLang}">
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="Русский" Tag="ru"/>
                                <ComboBoxItem Content="Deutsch" Tag="de"/>
                                <ComboBoxItem Content="日本語" Tag="jp"/>
                            </ComboBox>

                            <TextBox Text="{Binding NewConnectionString, Mode=TwoWay}"/>
                            <Button Content="apply" Command="{Binding SetNewConnectionStringCommand}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </StackPanel>

    </Grid>
</UserControl>
