<UserControl x:Class="WindowsDev.Views.Projects.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d">

    <Grid Margin="15">
        <TabControl>

            <!-- PROJECT -->
            <TabItem Header="Project">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Content="{DynamicResource BackButton}"
                                Width="100"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Left"
                                mah:ControlsHelper.CornerRadius="8"
                                Command="{Binding SwitchToMainViewCommand}"/>

                        <UserCtrl:TextBlock Grid.Row="1"
                                            Margin="0,0,0,10"
                                            CornerRadius="8"
                                            Header="{DynamicResource NameLabel}"
                                            Text="{Binding Name}"/>

                        <UserCtrl:TextBlock Grid.Row="2"
                                            CornerRadius="8"
                                            Header="{DynamicResource DescriptionLabel}"
                                            Text="{Binding Description}"/>
                    </Grid>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1">
                        <Button Content="Add"
                                mah:ControlsHelper.CornerRadius="8"
                                Command="{Binding OpenDialogCommand}"/>
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  ItemsSource="{Binding TaskItem}">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="{DynamicResource IdLabel}"
                                                Binding="{Binding Id}"
                                                Width="Auto"/>

                                <DataGridTemplateColumn Header="{DynamicResource NameLabel}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock TextTrimming="CharacterEllipsis">
                                            <Hyperlink Command="{Binding DataContext.OpenTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                       CommandParameter="{Binding}">
                                                <Run Text="{Binding Name}"/>
                                            </Hyperlink>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{DynamicResource DescriptionLabel}" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="{DynamicResource DeadlineLabel}"
                                                Binding="{Binding DeadLine, StringFormat=d}"
                                                Width="*"/>

                                <DataGridTextColumn Header="{DynamicResource CreatedAtLabel}"
                                                Binding="{Binding CreatedAt, StringFormat=d}"
                                                Width="*"/>

                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- SETTINGS -->
            <TabItem Header="Project Settings">
                <Grid Margin="15">
                    <TextBlock Text="Settings will be here"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>