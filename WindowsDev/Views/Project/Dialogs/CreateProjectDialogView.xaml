<UserControl
  x:Class="WindowsDev.Views.Projects.CreateProjectDialogView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
  xmlns:local="clr-namespace:WindowsDev.Controls.Users"
  xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
  dialogs:DialogParticipation.Register="{Binding}"
  mc:Ignorable="d"
  d:DesignHeight="450"
  d:DesignWidth="800"
>
  <!-- Project Form -->
  <StackPanel MaxWidth="400">
    <!-- Project Name Input -->
    <UserCtrl:HeaderTextBox
      Header="{DynamicResource CreateProject_Label_Name}"
      CornerRadius="8"
      Text="{Binding ProjectName, Mode=TwoWay}"
    />
    <!-- Project Description Input -->
    <UserCtrl:HeaderTextBox
      Header="{DynamicResource CreateProject_Label_Description}"
      CornerRadius="8"
      FieldHeight="100"
      ScrollBarVisibility="Auto"
      Text="{Binding ProjectDescription, Mode=TwoWay}"
    />

    <!-- Action Buttons -->
    <Grid Margin="0,20,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Button
        Grid.Column="0"
        Content="{DynamicResource CreateProject_Button_Create}"
        mah:ControlsHelper.CornerRadius="8"
        Margin="0,0,10,5"
        Command="{Binding CreateProjectCommand}"
      />
      <Button
        Grid.Column="1"
        Content="{DynamicResource CreateProject_Button_Cancel}"
        mah:ControlsHelper.CornerRadius="8"
        Margin="10,0,0,5"
        Command="{Binding CloseDialogCommand}"
      />
    </Grid>
  </StackPanel>
</UserControl>
