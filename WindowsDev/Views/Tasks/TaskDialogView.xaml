<UserControl x:Class="WindowsDev.Views.Tasks.TaskDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converter="clr-namespace:WindowsDev.Business.Services.TaskService.Converters;assembly=WindowsDev.Business"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             dialogs:DialogParticipation.Register="{Binding}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converter:TaskStatusToTextConverter x:Key="StatusToText"/>
        <converter:TaskPriorityToTextConverter x:Key="PriorityToText"/>
    </UserControl.Resources>

    <!-- Task Form -->
    <Grid MaxWidth="400" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Task Name Input -->
        <UserCtrl:HeaderTextBox Grid.Row="0"
                                 Header="{DynamicResource NameLabel}"
                                 Margin="0,0,0,10"
                                 CornerRadius="8"
                                 Text="{Binding Name}"/>

        <!-- Deadline Picker -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="{DynamicResource DeadlineLabel}" />
            <DatePicker
                    Margin="0,0,0,10"
                    Height="35"
                    mah:ControlsHelper.CornerRadius="8"
                    Text="{Binding DeadLine, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Progress, Priority, Status Selectors -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Progress Selector -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource ProgressLabel}"/>
                <ComboBox ItemsSource="{Binding Percents}"
                          SelectedItem="{Binding Progress}"
                          ItemStringFormat="{}{0}%">
                </ComboBox>
            </StackPanel>

            <!-- Priority Selector -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource PriorityLabel}"/>
                <ComboBox ItemsSource="{Binding Priorities}"
                          SelectedItem="{Binding Priority, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource PriorityToText}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Status Selector -->
            <StackPanel Grid.Column="4">
                <TextBlock Text="{DynamicResource StatusLabel}"/>
                <ComboBox ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding Status, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StatusToText}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Task Description Input -->
        <UserCtrl:HeaderTextBox Grid.Row="3"
                                 Header="{DynamicResource DescriptionLabel}"
                                 CornerRadius="8"
                                 FieldHeight="100"
                                 ScrollBarVisibility="Auto"
                                 Text="{Binding Description}"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button mah:ControlsHelper.CornerRadius="8" Padding="5,6,10,6">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button}">
                        <Setter Property="Command" Value="{Binding CreateTaskCommand}"/>
                        <Setter Property="Content" Value="{DynamicResource CreateButton}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Command" Value="{Binding EditTaskCommand}"/>
                                <Setter Property="Content" Value="{DynamicResource SaveTaskButton}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="{DynamicResource CancelButton}" Command="{Binding CancelCommand}"
                    mah:ControlsHelper.CornerRadius="8" Padding="10,6,5,6"/>
        </StackPanel>
    </Grid>
</UserControl>
