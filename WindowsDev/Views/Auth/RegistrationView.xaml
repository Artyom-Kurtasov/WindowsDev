<UserControl x:Class="WindowsDev.Views.Auth.RegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:WindowsDev.Business.Services.Registration.Validation.Converters;assembly=WindowsDev.Business"
             xmlns:local="clr-namespace:WindowsDev.Controls.Users"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="VisibilityConverter"/>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Main Content -->
            <StackPanel Grid.Row="1" Margin="10,0,10,0">
                <!-- Logo -->
                <UserCtrl:Logo Kind="TaskRound"
                           ViewBoxHeight="70" ViewBoxWidth="70"
                           Text="{DynamicResource RegTitle}"
                           HorizontalContentAlignment="Center"
                           HorizontalAlignment="Stretch"/>

                <!-- Registration Error Message -->
                <TextBlock Foreground="Red" HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRegistrationFailed}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource Registration_Failed}"/>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Login Input -->
                <UserCtrl:HeaderTextBox CornerRadius="8" Margin="0,20,0,0"
                                        Header="{DynamicResource LoginLabel}"
                                        Text="{Binding Login, Mode=TwoWay}"/>

                <!-- Login Availability Status -->
                <TextBlock Visibility="{Binding Login, Converter={StaticResource StringToVisibilityConverter}}"
                       Foreground="{Binding IsLoginAvailable, Converter={StaticResource BoolToBrushConverter}}" Margin="5,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoginAvailable}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource LoginAvailable}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsLoginAvailable}" Value="False">
                                    <Setter Property="Text" Value="{DynamicResource LoginTaken}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Username Input -->
                <UserCtrl:HeaderTextBox CornerRadius="8"
                                      Header="{DynamicResource UsernameLabel}" Margin="0,20,0,0"
                                      Text="{Binding Username, Mode=TwoWay}"/>

                <!-- Username Availability Status -->
                <TextBlock Visibility="{Binding Username, Converter={StaticResource StringToVisibilityConverter}}"
                           Foreground="{Binding IsUsernameAvailable, Converter={StaticResource BoolToBrushConverter}}" 
                           Margin="5,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUsernameAvailable}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource UsernameAvailable}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUsernameAvailable}" Value="False">
                                    <Setter Property="Text" Value="{DynamicResource UsernameTaken}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Password Input Section -->
                <StackPanel HorizontalAlignment="Stretch">

                    <UserCtrl:HeaderPasswordBox
                    Header="{DynamicResource PasswordLabel}"
                    HeaderFontSize="14"
                    Margin="0,20,0,0"
                    ShowRequirements="True"
                    CornerRadius="8"
                    Password="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Confirm Password Input -->
                <UserCtrl:HeaderPasswordBox CornerRadius="8" Margin="0,20,0,0"
                                  Header="{DynamicResource ConfirmPasswordLabel}"
                                  Password="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <!-- Sign Up Button -->
                <Button Margin="0,20,0,0"
                    mah:ControlsHelper.CornerRadius="8"
                    Command="{Binding SignUpCommand}"
                    Content="{DynamicResource SignUpButton}"/>


                <!-- Login Link -->
                <TextBlock HorizontalAlignment="Center"
                       MaxWidth="400">

                <Run Text="{DynamicResource ExistingUserText}"/>
                <Hyperlink Command="{Binding SwitchToAuthViewCommand}">
                    <TextBlock Text="{DynamicResource SignInButton}"/>
                </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
