<UserControl x:Class="WindowsDev.Views.Auth.AuthorizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.Controls.Users"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid MaxWidth="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">

            <!-- Logo -->
            <UserCtrl:Logo Kind="TaskRound"
                           ViewBoxHeight="70" ViewBoxWidth="70"
                           Text="{DynamicResource AuthTitle}"
                           FontSize="14"
                           HorizontalContentAlignment="Center"
                           HorizontalAlignment="Stretch" Margin="0,0,5,0"/>

            <!--Username-->
            <UserCtrl:AdvancedTextBox
                Header="{DynamicResource LoginLabel}"
                CornerRadius="8"
                Margin="20,20,20,0"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <!--Password-->
            <UserCtrl:PasswordBox
                Header="{DynamicResource PasswordLabel}"
                HeaderFontSize="14"
                Margin="20,20,20,0"
                CornerRadius="8"
                Password="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <!--SIGN IN BUTTON-->
            <Button mah:ControlsHelper.CornerRadius="8" Margin="20,20,20,0"
                    Command="{Binding AuthorizeCommand}">
                <TextBlock Text="{DynamicResource SignInButton}" FontSize="12" FontWeight="Bold"/>
            </Button>

            <!--LINK TO REGISTRATION-->
            <TextBlock HorizontalAlignment="Center">
                    <Run Text="{DynamicResource NewUserText}"/>
                    <Hyperlink Command="{Binding SwitchToRegViewCommand}">
                            <TextBlock Text="{DynamicResource SignUpButton}"/>
                    </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
