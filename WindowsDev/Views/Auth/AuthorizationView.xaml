<UserControl x:Class="WindowsDev.Views.Auth.AuthorizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.Controls.Users"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid MaxWidth="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">

            <!-- Logo -->
            <UserCtrl:Logo Kind="TaskRound"
                           ViewBoxHeight="70" ViewBoxWidth="70"
                           Text="{DynamicResource Authorization_Title}"
                           FontSize="14"
                           HorizontalContentAlignment="Center"
                           HorizontalAlignment="Stretch" Margin="0,0,5,0"/>



            <!-- Login Error Message -->
            <TextBlock Foreground="Red"
           Margin="20,20,20,0"
           Text="{Binding ErrorMessage}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility"
                    Value="Collapsed"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}"
                             Value="True">
                                <Setter Property="Visibility"
                            Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Login Input -->
            <UserCtrl:HeaderTextBox
                Header="{DynamicResource Authorization_Label_Login}"
                CornerRadius="8"
                Margin="20,20,20,0"
                Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <!-- Password Input -->
            <UserCtrl:HeaderPasswordBox
                Header="{DynamicResource Authorization_Label_Password}"
                HeaderFontSize="14"
                Margin="20,20,20,0"
                CornerRadius="8"
                Password="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                LinkText="{DynamicResource Authorization_Link_ForgotPassword}"
                LinkCommand="{Binding PasswordRecoveryCommand}"/>

            <!-- Sign In Button -->
            <Button mah:ControlsHelper.CornerRadius="8" Margin="20,20,20,0"
                    Command="{Binding AuthorizeCommand}">
                <TextBlock Text="{DynamicResource Authorization_Button_SignIn}" FontSize="12" FontWeight="Bold"/>
            </Button>

            <!-- Registration Link -->
            <TextBlock HorizontalAlignment="Center">
                    <Run Text="{DynamicResource Authorization_Helper_NewToApp}"/>
                    <Hyperlink Command="{Binding SwitchToRegViewCommand}">
                            <TextBlock Text="{DynamicResource Authorization_Link_SignUp}"/>
                    </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
