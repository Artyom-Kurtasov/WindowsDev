<UserControl x:Class="WindowsDev.Views.Auth.Dialogs.RecoverySteps.ThirdStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsDev.Views.Auth.Dialogs.RecoverySteps"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <!-- New Password Input -->
        <UserCtrl:HeaderPasswordBox Header="{DynamicResource RecoverySteps_Label_EnterNewPassword}"
                                    Password="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                    ShowRequirements="True"
                                    Margin="0,0,0,10"/>

        <!-- Confirm Password Input -->
        <UserCtrl:HeaderPasswordBox Header="{DynamicResource RecoverySteps_Label_ConfirmPassword}"
                                    Password="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
    </StackPanel>
</UserControl>
