<UserControl x:Class="WindowsDev.Views.Auth.Dialogs.RecoverySteps.FirstStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:local="clr-namespace:WindowsDev.Views.Auth.Dialogs.RecoverySteps"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <UserCtrl:HeaderTextBox
                Header="{DynamicResource EnterLoginLabel}"
                Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
    </Grid>
</UserControl>
