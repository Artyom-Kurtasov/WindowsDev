<UserControl x:Class="WindowsDev.Views.Auth.Dialogs.RecoveryCodeDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:WindowsDev.Views.Auth.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Введите код"/>

            <TextBox mah:ControlsHelper.CornerRadius="4" Margin="0,15,0,15"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            
            <TextBox mah:ControlsHelper.CornerRadius="4" MaxLength="6" Margin="0,15,0,15"
                     Text="{Binding RecoveryCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            
            <Button Content="Ok"
                    Command="{Binding ConfirmCommand}"/>
        </StackPanel>  
    </Grid>
</UserControl>
