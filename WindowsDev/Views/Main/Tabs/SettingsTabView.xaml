<UserControl x:Class="WindowsDev.Views.Main.Tabs.SettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:converter="clr-namespace:WindowsDev.Business.Services.SettingsManager;assembly=WindowsDev.Business"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             dialogs:DialogParticipation.Register="{Binding}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converter:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="30,20"
                    MaxWidth="600">

            <!-- Language Settings -->
            <TextBlock Text="{DynamicResource Settings_Label_Language}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,0,0,15"/>

            <Border Background="{DynamicResource MahApps.Brushes.ControlBackground}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,25">

                <StackPanel>

                    <!-- Language Selection -->
                    <ComboBox ItemsSource="{Binding Languages}"
                              SelectedValue="{Binding SelectedLang}"
                              Height="40">

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding ApplyLanguageCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                    </ComboBox>

                </StackPanel>

            </Border>

            <!-- Theme Settings -->
            <TextBlock Text="{DynamicResource Settings_Label_Theme}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,0,0,15"/>

            <Border Background="{DynamicResource MahApps.Brushes.ControlBackground}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,25">

                <StackPanel>


                    <!-- Theme Slider -->
                    <Slider Minimum="0"
                            Maximum="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding SelectedTheme}"
                            Margin="0,15,0,5"/>

                    <Grid>
                        <TextBlock Text="{DynamicResource Settings_Label_DarkTheme}"
                                   HorizontalAlignment="Left"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray}"/>

                        <TextBlock Text="{DynamicResource Settings_Label_LightTheme}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray}"/>
                    </Grid>

                </StackPanel>

            </Border>

            <!-- Database Settings -->
            <TextBlock Text="{DynamicResource Settings_Label_Database}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,0,0,15"/>

            <Border Background="{DynamicResource MahApps.Brushes.ControlBackground}"
                    CornerRadius="8"
                    Padding="20">

                <StackPanel>

                    <!-- Connection String Input -->
                    <UserCtrl:HeaderTextBox
                        Header="{DynamicResource Settings_Label_ConnectionString}"
                        HeaderFontSize="12"
                        Text="{Binding NewConnectionString, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                        Watermark="{DynamicResource Settings_Watermark_ConnectionString}"/>

                    <!-- Apply Button -->
                    <Button Content="{DynamicResource Settings_Button_Apply}"
                            Command="{Binding SetNewConnectionStringCommand}"
                            Style="{DynamicResource MahApps.Styles.Button.Dialogs.Accent}"
                            Width="120"
                            Margin="0,15,0,0"
                            HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
