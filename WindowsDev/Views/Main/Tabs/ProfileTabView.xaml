<UserControl x:Class="WindowsDev.Views.Main.Tabs.ProfileTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="30,20"
                    MaxWidth="600">

            <UserCtrl:HeaderTextBlock
                Header="User Id"
                Text="{Binding Id}"
                HeaderFontSize="12"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray1}"
                BorderThickness="1"
                Margin="0,0,0,15"/>

            <UserCtrl:HeaderTextBox
                Header="Login"
                HeaderFontSize="12"
                Text="{Binding Login, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Watermark="Enter login"
                Margin="0,0,0,15"/>

            <UserCtrl:HeaderTextBox
                Header="Username"
                HeaderFontSize="12"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Watermark="Enter name"
                Margin="0,0,0,15"/>

            <Separator Margin="0,10,0,20"/>

            <TextBlock Text="CHANGE PASSWORD"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,0,0,15"/>

            <UserCtrl:HeaderPasswordBox
                Header="Current Password"
                HeaderFontSize="12"
                Password="{Binding CurrentPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Watermark="Enter current password"
                Margin="0,0,0,15"/>

            <UserCtrl:HeaderPasswordBox
                Header="New Password"
                HeaderFontSize="12"
                Password="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                ShowRequirements="True"
                Watermark="Enter new password"
                Margin="0,0,0,15"/>

            <UserCtrl:HeaderPasswordBox
                Header="Confirm Password"
                HeaderFontSize="12"
                Password="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Watermark="Confirm password"
                Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Save"
                        Style="{DynamicResource MahApps.Styles.Button.Accent}"
                        Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        Content="Logout"
                        Style="{StaticResource MahApps.Styles.Button}"/>
            </Grid>

        </StackPanel>

    </ScrollViewer>

</UserControl>