<UserControl x:Class="WindowsDev.Views.Main.Tabs.ProjectsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:UserCtrl="clr-namespace:WindowsDev.Controls.Users"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialogs="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             dialogs:DialogParticipation.Register="{Binding}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Button Content="{DynamicResource AddButton}" 
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        Command="{Binding OpenDialogCommand}"/>
                <Button Content="{DynamicResource DeleteButton}" 
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        Command="{Binding DeleteSelectedProjectsCommand}" 
                        Margin="10,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <UserCtrl:HeaderTextBox   HorizontalAlignment="Right"
                                          Watermark="{DynamicResource SearchWatermark}"
                                          Margin="5,0,0,0"
                                          Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <Button Content="{DynamicResource SearchButton}" 
                        Command="{Binding SearchCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <DataGrid ItemsSource="{Binding ProjectsList}"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  CanUserAddRows="False"
                  VerticalAlignment="Stretch">
                <DataGrid.Columns>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                      Style="{DynamicResource MetroDataGridCheckBox}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Binding="{Binding Id}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource IdLabel}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="1*">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource NameLabel}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                <Hyperlink Command="{Binding DataContext.OpenProjectCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}">
                                    <Run Text="{Binding Name}"/>
                                </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="3*">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource DescriptionLabel}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" 
                                       TextWrapping="NoWrap" 
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="50"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy}}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource CreatedAtLabel}"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10">
            <Button Content="{DynamicResource PrevButton}" 
                    Command="{Binding PrevPageCommand}" 
                    Margin="0,0,20,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square}"/>
            <Button Content="{DynamicResource NextButton}" 
                    Command="{Binding NextPageCommand}" 
                    Margin="20,0,0,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
        </StackPanel>
    </Grid>
</UserControl>
