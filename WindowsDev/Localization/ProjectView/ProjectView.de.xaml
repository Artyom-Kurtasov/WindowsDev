<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Project_Label_Name">Name</sys:String>
    <sys:String x:Key="Project_Label_Description">Beschreibung</sys:String>
    <sys:String x:Key="Project_Label_Id">ID</sys:String>
    <sys:String x:Key="Project_Label_Deadline">Frist</sys:String>
    <sys:String x:Key="Project_Label_CreatedAt">Erstellt am</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Project_Button_Back">Zurück</sys:String>
    <sys:String x:Key="Project_Button_Add">Hinzufügen</sys:String>
    <sys:String x:Key="Project_Button_Delete">Löschen</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Project_Watermark_Search">Suchen...</sys:String>

    <!-- Status Filters -->
    <sys:String x:Key="Project_Filter_All">Alle</sys:String>
    <sys:String x:Key="Project_Filter_Closed">Abgeschlossen</sys:String>
    <sys:String x:Key="Project_Filter_InProgress">In Bearbeitung</sys:String>
    <sys:String x:Key="Project_Filter_Frozen">Eingefroren</sys:String>

</ResourceDictionary>