<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Project_Label_Name">名前</sys:String>
    <sys:String x:Key="Project_Label_Description">説明</sys:String>
    <sys:String x:Key="Project_Label_Id">ID</sys:String>
    <sys:String x:Key="Project_Label_Deadline">期限</sys:String>
    <sys:String x:Key="Project_Label_CreatedAt">作成日</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Project_Button_Back">戻る</sys:String>
    <sys:String x:Key="Project_Button_Add">追加</sys:String>
    <sys:String x:Key="Project_Button_Delete">削除</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Project_Watermark_Search">検索...</sys:String>

    <!-- Status Filters -->
    <sys:String x:Key="Project_Filter_All">すべて</sys:String>
    <sys:String x:Key="Project_Filter_Closed">完了</sys:String>
    <sys:String x:Key="Project_Filter_InProgress">進行中</sys:String>
    <sys:String x:Key="Project_Filter_Frozen">凍結</sys:String>

</ResourceDictionary>