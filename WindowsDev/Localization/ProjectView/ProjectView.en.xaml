<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Project_Label_Name">Name</sys:String>
    <sys:String x:Key="Project_Label_Description">Description</sys:String>
    <sys:String x:Key="Project_Label_Id">ID</sys:String>
    <sys:String x:Key="Project_Label_Deadline">Deadline</sys:String>
    <sys:String x:Key="Project_Label_CreatedAt">Created at</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Project_Button_Back">Back</sys:String>
    <sys:String x:Key="Project_Button_Add">Add</sys:String>
    <sys:String x:Key="Project_Button_Delete">Delete</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Project_Watermark_Search">Search...</sys:String>

    <!-- Status Filters -->
    <sys:String x:Key="Project_Label_All">All</sys:String>
    <sys:String x:Key="Project_Label_Closed">Closed</sys:String>
    <sys:String x:Key="Project_Label_InProgress">In progress</sys:String>

</ResourceDictionary>