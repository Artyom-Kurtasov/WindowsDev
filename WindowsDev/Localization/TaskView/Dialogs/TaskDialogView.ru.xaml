<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="TaskDialog_Label_Name">Название</sys:String>
    <sys:String x:Key="TaskDialog_Label_Deadline">Дедлайн</sys:String>
    <sys:String x:Key="TaskDialog_Label_Progress">Прогресс</sys:String>
    <sys:String x:Key="TaskDialog_Label_Priority">Приоритет</sys:String>
    <sys:String x:Key="TaskDialog_Label_Status">Статус</sys:String>
    <sys:String x:Key="TaskDialog_Label_Description">Описание</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="TaskDialog_Button_Create">Создать</sys:String>
    <sys:String x:Key="TaskDialog_Button_Save">Сохранить</sys:String>
    <sys:String x:Key="TaskDialog_Button_Cancel">Отмена</sys:String>

    <!-- Warnings -->
    <sys:String x:Key="TaskDialog_Warning_EnterName">Введите имя задачи.</sys:String>
    
    <!-- Statuses -->
    <sys:String x:Key="Task_Status_Completed">Выполнено</sys:String>
    <sys:String x:Key="Task_Status_InProgress">В процессе</sys:String>
    <sys:String x:Key="Task_Status_Closed">Закрыто</sys:String>
    <sys:String x:Key="Task_Status_Frozen">Заморожено</sys:String>

    <!-- Priorities -->
    <sys:String x:Key="Task_Priority_Critical">Критический</sys:String>
    <sys:String x:Key="Task_Priority_High">Высокий</sys:String>
    <sys:String x:Key="Task_Priority_Medium">Средний</sys:String>
    <sys:String x:Key="Task_Priority_Low">Низкий</sys:String>

</ResourceDictionary>