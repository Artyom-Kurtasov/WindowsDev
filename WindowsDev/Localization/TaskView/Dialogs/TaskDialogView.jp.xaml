<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="TaskDialog_Label_Name">名前</sys:String>
    <sys:String x:Key="TaskDialog_Label_Deadline">期限</sys:String>
    <sys:String x:Key="TaskDialog_Label_Progress">進捗</sys:String>
    <sys:String x:Key="TaskDialog_Label_Priority">優先度</sys:String>
    <sys:String x:Key="TaskDialog_Label_Status">ステータス</sys:String>
    <sys:String x:Key="TaskDialog_Label_Description">説明</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="TaskDialog_Button_Create">作成</sys:String>
    <sys:String x:Key="TaskDialog_Button_Save">保存</sys:String>
    <sys:String x:Key="TaskDialog_Button_Cancel">キャンセル</sys:String>
    
    <!-- Warnings -->
    <sys:String x:Key="TaskDialog_Warning_EnterName">タスク名を入力してください。</sys:String>

    <!-- Statuses -->
    <sys:String x:Key="Task_Status_Complited">完了</sys:String>
    <sys:String x:Key="Task_Status_InProgress">進行中</sys:String>
    <sys:String x:Key="Task_Status_Closed">クローズ</sys:String>
    <sys:String x:Key="Task_Status_Frozen">凍結</sys:String>

    <!-- Priorities -->
    <sys:String x:Key="Task_Priority_Critical">クリティカル</sys:String>
    <sys:String x:Key="Task_Priority_High">高</sys:String>
    <sys:String x:Key="Task_Priority_Medium">中</sys:String>
    <sys:String x:Key="Task_Priority_Low">低</sys:String>

</ResourceDictionary>