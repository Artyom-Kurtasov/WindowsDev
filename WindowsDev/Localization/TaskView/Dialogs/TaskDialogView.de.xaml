<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="TaskDialog_Label_Name">Name</sys:String>
    <sys:String x:Key="TaskDialog_Label_Deadline">Frist</sys:String>
    <sys:String x:Key="TaskDialog_Label_Progress">Fortschritt</sys:String>
    <sys:String x:Key="TaskDialog_Label_Priority">Priorität</sys:String>
    <sys:String x:Key="TaskDialog_Label_Status">Status</sys:String>
    <sys:String x:Key="TaskDialog_Label_Description">Beschreibung</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="TaskDialog_Button_Create">Erstellen</sys:String>
    <sys:String x:Key="TaskDialog_Button_Save">Speichern</sys:String>
    <sys:String x:Key="TaskDialog_Button_Cancel">Abbrechen</sys:String>
    
    <!-- Warnings -->
    <sys:String x:Key="TaskDialog_Warning_EnterName">Aufgabenname eingeben.</sys:String>

    <!-- Statuses -->
    <sys:String x:Key="Task_Status_Complited">Abgeschlossen</sys:String>
    <sys:String x:Key="Task_Status_InProgress">In Bearbeitung</sys:String>
    <sys:String x:Key="Task_Status_Closed">Geschlossen</sys:String>
    <sys:String x:Key="Task_Status_Frozen">Eingefroren</sys:String>

    <!-- Priorities -->
    <sys:String x:Key="Task_Priority_Critical">Kritisch</sys:String>
    <sys:String x:Key="Task_Priority_High">Hoch</sys:String>
    <sys:String x:Key="Task_Priority_Medium">Mittel</sys:String>
    <sys:String x:Key="Task_Priority_Low">Niedrig</sys:String>

</ResourceDictionary>