<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="TaskDialog_Label_Name">Name</sys:String>
    <sys:String x:Key="TaskDialog_Label_Deadline">Deadline</sys:String>
    <sys:String x:Key="TaskDialog_Label_Progress">Progress</sys:String>
    <sys:String x:Key="TaskDialog_Label_Priority">Priority</sys:String>
    <sys:String x:Key="TaskDialog_Label_Status">Status</sys:String>
    <sys:String x:Key="TaskDialog_Label_Description">Description</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="TaskDialog_Button_Create">Create</sys:String>
    <sys:String x:Key="TaskDialog_Button_Save">Save</sys:String>
    <sys:String x:Key="TaskDialog_Button_Cancel">Cancel</sys:String>

    <!-- Warnings -->
    <sys:String x:Key="TaskDialog_Warning_EnterName">Enter task name.</sys:String>

    <!-- Statuses -->
    <sys:String x:Key="Task_Status_Complited">Completed</sys:String>
    <sys:String x:Key="Task_Status_InProgress">In Progress</sys:String>
    <sys:String x:Key="Task_Status_Closed">Closed</sys:String>
    <sys:String x:Key="Task_Status_Frozen">Frozen</sys:String>

    <!-- Priorities -->
    <sys:String x:Key="Task_Priority_Critical">Critical</sys:String>
    <sys:String x:Key="Task_Priority_High">High</sys:String>
    <sys:String x:Key="Task_Priority_Medium">Medium</sys:String>
    <sys:String x:Key="Task_Priority_Low">Low</sys:String>

</ResourceDictionary>