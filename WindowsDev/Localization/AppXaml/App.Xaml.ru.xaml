<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Errors -->
    <sys:String x:Key="AppXaml_Error_Generic">Произошла непредвиденная ошибка. Попробуйте перезапустить приложение.</sys:String>
    <sys:String x:Key="AppXaml_Error_Shutdown">Произошла критическая ошибка. Приложение будет закрыто.</sys:String>
    <sys:String x:Key="AppXaml_Error_DatabaseFatal">Не удалось подключиться к базе данных. Приложение будет закрыто.</sys:String>

</ResourceDictionary>