<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- Errors -->
    <sys:String x:Key="AppXaml_Error_Generic">予期しないエラーが発生しました。アプリケーションを再起動してください。</sys:String>
    <sys:String x:Key="AppXaml_Error_Shutdown">重大なエラーが発生しました。アプリケーションを終了します。</sys:String>
    <sys:String x:Key="AppXaml_Error_DatabaseFatal">データベースに接続できませんでした。アプリケーションを終了します。</sys:String>

</ResourceDictionary>