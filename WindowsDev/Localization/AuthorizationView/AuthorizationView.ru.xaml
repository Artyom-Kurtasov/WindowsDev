<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Title -->
    <sys:String x:Key="Authorization_Title">Войти в TaskManager</sys:String>
    
    <!-- Lables -->
    <sys:String x:Key="Authorization_Label_Login">Логин:</sys:String>
    <sys:String x:Key="Authorization_Label_Password">Пароль:</sys:String>

    <!-- Buttons & Links -->
    <sys:String x:Key="Authorization_Button_SignIn">Войти</sys:String>
    <sys:String x:Key="Authorization_Link_SignUp">Зарегистрироваться</sys:String>
    <sys:String x:Key="Authorization_Link_ForgotPassword">Забыли пароль?</sys:String>
    
    <!-- Helpers -->
    <sys:String x:Key="Authorization_Helper_NewToApp">Впервые в TaskManager?</sys:String>

    <!-- Errors -->
    <sys:String x:Key="Authorization_Error_InvalidCredentials">Неверный логин или пароль</sys:String>

</ResourceDictionary>