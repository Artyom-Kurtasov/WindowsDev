<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Title -->
    <sys:String x:Key="Authorization_Title">Sign In to TaskManager</sys:String>

    <!-- Lables & Helpers -->
    <sys:String x:Key="Authorization_Label_Login">Login:</sys:String>
    <sys:String x:Key="Authorization_Label_Password">Password:</sys:String>
    <sys:String x:Key="Authorization_Helper_NewToApp">New to TaskManager?</sys:String>

    <!-- Buttons & Links -->
    <sys:String x:Key="Authorization_Button_SignIn">Sign In</sys:String>
    <sys:String x:Key="Authorization_Link_SignUp">Sign Up</sys:String>
    <sys:String x:Key="Authorization_Link_ForgotPassword">Forgot Password?</sys:String>

    <!-- Errors -->
    <sys:String x:Key="Authorization_Error_InvalidCredentials">Invalid login or password</sys:String>

</ResourceDictionary>