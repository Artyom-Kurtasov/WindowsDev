<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Settings_Label_Language">Language</sys:String>
    <sys:String x:Key="Settings_Label_Theme">Theme</sys:String>
    <sys:String x:Key="Settings_Label_Database">Database</sys:String>
    <sys:String x:Key="Settings_Label_ConnectionString">Connection string</sys:String>
    <sys:String x:Key="Settings_Label_DarkTheme">Dark</sys:String>
    <sys:String x:Key="Settings_Label_LightTheme">Light</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Settings_Button_Apply">Apply</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Settings_Watermark_ConnectionString">Server=localhost;Database=MyDb;...</sys:String>

    <!-- Warnings -->
    <sys:String x:Key="Settings_Warning_InvalidConnectionString">Invalid connection string.</sys:String>

</ResourceDictionary>