<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Settings_Label_Language">言語</sys:String>
    <sys:String x:Key="Settings_Label_Theme">テーマ</sys:String>
    <sys:String x:Key="Settings_Label_Database">データベース</sys:String>
    <sys:String x:Key="Settings_Label_ConnectionString">接続文字列</sys:String>
    <sys:String x:Key="Settings_Label_DarkTheme">ダーク</sys:String>
    <sys:String x:Key="Settings_Label_LightTheme">ライト</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Settings_Button_Apply">適用</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Settings_Watermark_ConnectionString">Server=localhost;Database=MyDb;...</sys:String>
    
    <!-- Warnings -->
    <sys:String x:Key="Settings_Warning_InvalidConnectionString">接続文字列が無効です。</sys:String>

</ResourceDictionary>