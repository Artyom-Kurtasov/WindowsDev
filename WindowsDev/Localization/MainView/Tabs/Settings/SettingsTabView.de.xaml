<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Settings_Label_Language">Sprache</sys:String>
    <sys:String x:Key="Settings_Label_Theme">Design</sys:String>
    <sys:String x:Key="Settings_Label_Database">Datenbank</sys:String>
    <sys:String x:Key="Settings_Label_ConnectionString">Verbindungszeichenfolge</sys:String>
    <sys:String x:Key="Settings_Label_DarkTheme">Dunkel</sys:String>
    <sys:String x:Key="Settings_Label_LightTheme">Hell</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Settings_Button_Apply">Übernehmen</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Settings_Watermark_ConnectionString">Server=localhost;Database=MyDb;...</sys:String>
    
    <!-- Warnings -->
    <sys:String x:Key="Settings_Warning_InvalidConnectionString">Ungültige Verbindungszeichenfolge.</sys:String>

</ResourceDictionary>