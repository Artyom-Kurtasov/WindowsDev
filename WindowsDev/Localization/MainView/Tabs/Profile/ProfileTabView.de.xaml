<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Labels -->
    <sys:String x:Key="Profile_Label_UserId">Benutzer-ID:</sys:String>
    <sys:String x:Key="Profile_Label_Login">Benutzername:</sys:String>
    <sys:String x:Key="Profile_Label_Username">Anzeigename:</sys:String>
    <sys:String x:Key="Profile_Label_CurrentPassword">Aktuelles Passwort:</sys:String>
    <sys:String x:Key="Profile_Label_NewPassword">Neues Passwort:</sys:String>
    <sys:String x:Key="Profile_Label_ConfirmPassword">Passwort bestätigen:</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Profile_Button_Save">Speichern</sys:String>
    <sys:String x:Key="Profile_Button_Logout">Abmelden</sys:String>

    <!-- Watermarks -->
    <sys:String x:Key="Profile_Watermark_CurrentPassword">Aktuelles Passwort eingeben</sys:String>
    <sys:String x:Key="Profile_Watermark_NewPassword">Neues Passwort eingeben</sys:String>
    <sys:String x:Key="Profile_Watermark_ConfirmPassword">Neues Passwort bestätigen</sys:String>

    <!-- Change Password Section -->
    <sys:String x:Key="Profile_Label_ChangePassword">Passwort ändern</sys:String>
    
    <!-- Errors -->
    <sys:String x:Key="Profile_Error_NewPasswordSameAsCurrent">Das neue Passwort darf nicht mit dem alten übereinstimmen.</sys:String>
    <sys:String x:Key="Profile_Error_PasswordsDontMatch">Passwörter stimmen nicht überein.</sys:String>
    <sys:String x:Key="Profile_Error_InvalidCurrentPassword">Ungültiges aktuelles Passwort.</sys:String>
    <sys:String x:Key="Profile_Error_NewUsernameSameAsCurrent">Der neue Benutzername darf nicht mit dem alten übereinstimmen.</sys:String>
    <sys:String x:Key="Profile_Error_UsernameAlreadyTaken">Dieser Benutzername wird bereits von einem anderen Benutzer verwendet.</sys:String>
    
    <!-- Success -->
    <sys:String x:Key="Profile_Success_UsernameChanged">Benutzername wurde erfolgreich geändert.</sys:String>
    <sys:String x:Key="Profile_Success_PasswordChanged">Passwort wurde erfolgreich geändert.</sys:String>

</ResourceDictionary>